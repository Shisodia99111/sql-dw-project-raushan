--1. Inserting data from CSV to CRM Customer Info Table inside Bronze Schema.
TRUNCATE TABLE bronze.crm_cust_info; 
BULK INSERT bronze.crm_cust_info 
FROM 'E:\1. SQL\sql-ultimate-course\sql_dw_project_raushan\source_crm\cust_info.csv'
WITH (
		FIRSTROW = 2,
		FIELDTERMINATOR = ',',
		TABLOCK
	);


